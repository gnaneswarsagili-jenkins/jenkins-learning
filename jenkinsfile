pipeline {
    agent any

    stages {
        stage('Use Credential') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'demo-credential', usernameVariable: 'USR', passwordVariable: 'PWD')]) {
                    bat 'echo Username is %USR%'
                    bat 'echo Password is masked by Jenkins'
                }
            }
        }
    }

    post {
        always {
            echo 'Pipeline completed'
        }
    }
}
