pipeline {
    agent any

    parameters {
        string(name: 'PACKAGE_NAME', defaultValue: 'sample_package.zip', description: 'Migration package name')
        choice(name: 'SOURCE_ENV', choices: ['DEV'], description: 'Source environment')
        choice(name: 'TARGET_ENV', choices: ['TEST'], description: 'Target environment')
    }

    stages {
        stage('Checkout Info') {
            steps {
                echo "Package: ${params.PACKAGE_NAME}"
                echo "Source: ${params.SOURCE_ENV}"
                echo "Target: ${params.TARGET_ENV}"
            }
        }

        stage('Run Deployment Script') {
            steps {
                bat 'deploy_simulation.bat'
            }
        }
    }

    post {
        always {
            echo 'Pipeline completed'
        }
        success {
            echo 'Pipeline succeeded'
        }
        failure {
            echo 'Pipeline failed'
        }
    }
}
